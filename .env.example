# ============================================================================
# CyberMarketTrack — environment variables template
# Copy this file to .env and adjust the values. NEVER commit the real .env.
# ============================================================================

# SQLite database file (relative to project root). Keep it under data/ so the
# Docker volume and the backup script cover it.
DATABASE_URL="file:./data/cybermarkettrack.db"

# No admin credentials here: on first run (empty database) the admin account is
# created from the login page — you choose the username and password there. So
# no default password is ever stored in the repo or the environment.

# Freshness threshold in months: entities not updated for longer get the
# "to re-check" badge (default 12)
FRESHNESS_MONTHS="12"

# Auth.js session encryption secret. Generate one with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"
# Required when self-hosting (Docker) so Auth.js trusts the Host header
AUTH_TRUST_HOST="true"
